#!/bin/sh
# Run after install — create dirs and seed a default config if none exists.

PKG_DIR="/var/packages/SoundTouchBridge/target"
mkdir -p "$PKG_DIR/etc" "$PKG_DIR/var"

if [ ! -f "$PKG_DIR/etc/config.yaml" ]; then
    cp "$PKG_DIR/etc/config.yaml.example" "$PKG_DIR/etc/config.yaml" 2>/dev/null || true
fi

chmod 755 "$PKG_DIR/bin/bridge"
exit 0
